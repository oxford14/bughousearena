NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "true" to use Firebase Emulator Suite locally
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Optional — used when Origin header is missing (PayMongo redirect URLs)
# Local: http://localhost:3000
# Production: https://bughousearena.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayMongo (https://dashboard.paymongo.com/developers) — server-only, same as RentPilot
PAYMONGO_SECRET_KEY=sk_test_your_secret_key
PAYMONGO_WEBHOOK_SECRET=whsk_your_webhook_secret

# Firebase Admin — required to credit coins after PayMongo payment
# Option A (recommended): save the full JSON from Firebase Console as:
#   firebase-service-account.json  (project root, gitignored)
#
# Option B: paste the full JSON (one line) into .env.local:
#   FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# Option C: private key + client email (both required):
#   FIREBASE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#   FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@bughousearena.iam.gserviceaccount.com
#
# Or: GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# PayMongo webhook (register in dashboard):
#   Local (via ngrok): https://YOUR_NGROK/api/paymongo/webhook
#   Production: https://bughousearena.com/api/paymongo/webhook
# Event: checkout_session.payment.paid
