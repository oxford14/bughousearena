rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function matchData(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    function isMatchParticipant(matchId) {
      let data = matchData(matchId);
      return isSignedIn() && (
        request.auth.uid in data.get('playerUids', []) ||
        uidInMatchPlayers(data.get('players', []))
      );
    }

    function uidInMatchPlayers(players) {
      return (players.size() > 0 && players[0].uid == request.auth.uid) ||
        (players.size() > 1 && players[1].uid == request.auth.uid) ||
        (players.size() > 2 && players[2].uid == request.auth.uid) ||
        (players.size() > 3 && players[3].uid == request.auth.uid);
    }

    function isBoardOwner(matchId, boardId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/matches/$(matchId)/boards/$(boardId)).data.playerUid == request.auth.uid;
    }

    function houseMemberRole(houseId) {
      return get(/databases/$(database)/documents/houses/$(houseId)/members/$(request.auth.uid)).data.role;
    }

    function isHouseAdmin(houseId) {
      return isSignedIn() &&
        houseMemberRole(houseId) in ['founder', 'steward'];
    }

    function isHouseMember(houseId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/houses/$(houseId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['arenaCoins', 'firstTopUpBonusUsedPackIds', 'ownedItems', 'equippedBoardTheme', 'equippedPieceSet', 'equippedVictoryFx', 'equippedEmoteIds', 'equippedAvatarFrame', 'dailyStreak', 'lastDailyClaimDateKey', 'referralCode', 'referredByUid', 'completedMatches']);
      allow delete: if false;

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) || isOwner(friendId);
        allow delete: if isOwner(userId);
      }

      match /friendRequests/{requestId} {
        // Split get/list: OR with resource.data breaks list queries even for owners.
        allow get: if isOwner(userId) ||
          (isSignedIn() && resource.data.fromUid == request.auth.uid);
        allow list: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.fromUid == request.auth.uid &&
          request.resource.data.toUid == userId &&
          request.resource.data.status == 'pending';
        allow update: if isOwner(userId) ||
          (isSignedIn() && resource.data.fromUid == request.auth.uid);
        allow delete: if isOwner(userId);
      }

      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.fromUid == request.auth.uid;
        allow update, delete: if isOwner(userId);
      }

      match /partyInvites/{inviteId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.resource.data.toUid == userId &&
          request.resource.data.fromUid == request.auth.uid;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /session/{sessionId} {
        // Friends list / party UI need to see whether someone is in a match.
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isOwner(userId);
      }
    }

    match /matchmaking/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.auth.uid in request.resource.data.memberUids;
      // Ephemeral queue: any signed-in client may delete entries when a match
      // is formed (the creator removes all matched queue docs in one batch).
      allow delete: if isSignedIn();
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
    }

    match /parties/{partyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.leaderUid == request.auth.uid &&
        request.auth.uid in request.resource.data.memberUids &&
        request.resource.data.memberUids.size() >= 1 &&
        request.resource.data.members.size() >= 1;
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.memberUids ||
        request.auth.uid in request.resource.data.memberUids
      );
      allow delete: if isSignedIn() &&
        request.auth.uid in resource.data.memberUids;
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isMatchParticipant(matchId);
      allow delete: if false;

      match /boards/{boardId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isBoardOwner(matchId, boardId) || isMatchParticipant(matchId);
        allow delete: if false;
      }

      match /moves/{moveId} {
        allow read: if isMatchParticipant(matchId);
        allow create: if isMatchParticipant(matchId) && (
          request.resource.data.playerId == request.auth.uid ||
          request.resource.data.move == 'partner-sync' ||
          (matchData(matchId).get('hasBots', false) == true &&
            request.resource.data.playerId in matchData(matchId).get('botUids', []))
        );
        allow update, delete: if false;
      }

      match /setupChat/{messageId} {
        allow get: if isMatchParticipant(matchId);
        allow list: if isMatchParticipant(matchId) && request.query.limit <= 100;
        allow create: if isMatchParticipant(matchId) &&
          matchData(matchId).status == 'setup' &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.team in [1, 2];
        allow update, delete: if false;
      }

      match /chat/{messageId} {
        allow get: if isMatchParticipant(matchId);
        allow list: if isMatchParticipant(matchId) && request.query.limit <= 100;
        allow create: if isMatchParticipant(matchId) &&
          matchData(matchId).status in ['setup', 'active'] &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.team in [1, 2] &&
          request.resource.data.scope in ['team', 'all'] &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }
    }

    match /privateRooms/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.hostId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() &&
        resource.data.hostId == request.auth.uid;
    }

    match /houses/{houseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.founderId == request.auth.uid;
      allow update: if isHouseAdmin(houseId);
      allow delete: if isSignedIn() &&
        resource.data.founderId == request.auth.uid;

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          isHouseAdmin(houseId) ||
          (memberId == request.auth.uid &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('houseId', null) == null &&
            get(/databases/$(database)/documents/houses/$(houseId)).data.get('autoAccept', false) == true)
        );
        allow update: if isHouseAdmin(houseId);
        allow delete: if isHouseAdmin(houseId) || memberId == request.auth.uid;
      }

      match /chat/{messageId} {
        allow read: if isHouseMember(houseId);
        allow create: if isHouseMember(houseId) &&
          request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /leaderboards/{boardType}/entries/{entryId} {
      allow read: if true;
      allow create, update: if isSignedIn() &&
        (entryId == request.auth.uid || boardType == 'houses');
      allow delete: if false;
    }

    match /matchHistory/{userId}/games/{gameId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(userId);
    }

    match /voiceSignals/{roomId}/candidates/{candidateId} {
      // Signals can only be read by the teammate they are addressed to.
      allow read: if isSignedIn() && resource.data.to == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.to is string &&
        request.resource.data.to != request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
    }

    match /coinPurchases/{purchaseId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /coinLedger/{entryId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /stakeLocks/{lockId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /redemptionRequests/{requestId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /referrals/{referredUid} {
      allow read: if isSignedIn() && (
        request.auth.uid == referredUid ||
        resource.data.referrerUid == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    match /tournaments/{tournamentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /teams/{teamId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /members/{memberUid} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    match /worldChat/{messageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.query.limit <= 100;
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.displayName is string &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500;
      allow update, delete: if false;
    }

    // Server-only rate limit counters (Admin SDK).
    match /rateLimits/{id} {
      allow read, write: if false;
    }
  }
}
