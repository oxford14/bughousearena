# Local / shared defaults — copy to .env and fill in values.
# Never commit .env or .secret.local (they are gitignored).
#
# PayMongo powers Arena Coin top-ups via Next.js API routes (RentPilot-style).
# Keys go in the project root .env.local (NOT in NEXT_PUBLIC_* vars).

# PayMongo secret API key (sk_test_... or sk_live_...)
PAYMONGO_SECRET_KEY=

# Webhook signing secret from PayMongo dashboard
PAYMONGO_WEBHOOK_SECRET=

# Optional fallback when Origin header is missing
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin service account — firebase-service-account.json in project root
# (see .env.local.example)

# Next.js webhook URL (register in PayMongo):
#   http://localhost:3000/api/paymongo/webhook  (use ngrok for local testing)
#   https://bughousearena.com/api/paymongo/webhook
# Event: checkout_session.payment.paid

# Legacy Cloud Functions (optional backup — client uses Next.js routes):
#   https://us-central1-bughousearena.cloudfunctions.net/paymongoWebhook
